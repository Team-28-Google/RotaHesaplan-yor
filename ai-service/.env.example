# ai-service ortam değişkenleri (kök .env.example'ın AI servisini ilgilendiren alt kümesi)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

LLM_PROVIDER=nvidia

NVIDIA_API_KEY=nvapi-xxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_CHAT_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_EMBED_MODEL=nvidia/nv-embedqa-e5-v5
EMBED_DIM=1024

GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=text-embedding-004

# SERPAPI_KEY: YALNIZ seed script'leri kullanır (yeni şehir üretimi); uygulama akışı tamamen Google
SERPAPI_KEY=your-serpapi-key
GOOGLE_MAPS_API_KEY=
# Google SUNUCU anahtarı (Weather + Routes + Places — App restriction: None, API restrictions ile kilitle)
GOOGLE_SERVER_API_KEY=
# (eski ad — GOOGLE_SERVER_API_KEY boşsa yedek olarak okunur)
GOOGLE_WEATHER_API_KEY=
OPENWEATHER_API_KEY=your-openweather-key
