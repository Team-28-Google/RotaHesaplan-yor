# ============================================================
# SANA — Ortam Değişkenleri ŞABLONU
# Bu dosyayı kopyalayıp `.env` yapın ve gerçek değerleri girin.
# `.env` ASLA git'e commit edilmez (bkz. .gitignore).
# ============================================================

# --- Supabase (app + ai-service) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key            # mobil uygulama kullanır
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # SADECE ai-service kullanır (gizli!)

# --- LLM / Embedding Sağlayıcı ---
LLM_PROVIDER=nvidia                                # nvidia | gemini

# NVIDIA NIM (OpenAI uyumlu) — https://build.nvidia.com
NVIDIA_API_KEY=nvapi-xxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_CHAT_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_EMBED_MODEL=nvidia/nv-embedqa-e5-v5
EMBED_DIM=1024                                      # nv-embedqa-e5-v5 = 1024

# Gemini (alternatif sağlayıcı) — https://aistudio.google.com
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=text-embedding-004              # not: 768 boyut → EMBED_DIM=768

# --- Harita verisi (mekan + mesafe) ---
MAPS_PROVIDER=serpapi                              # serpapi | google
SERPAPI_KEY=your-serpapi-key                        # https://serpapi.com — 250 istek/ay ücretsiz, kart gerekmez
GOOGLE_MAPS_API_KEY=your-google-maps-key           # SADECE app harita gösterimi (Android SDK, mobilde ücretsiz)

# --- Hava Durumu ---
OPENWEATHER_API_KEY=your-openweather-key
