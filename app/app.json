{
  "expo": {
    "name": "SANA",
    "slug": "rota-hesaplaniyor",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mamikaplaan.sana",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Rotayı dışarıda takip ederken konumunu haritada göstermek için."
      }
    },
    "android": {
      "package": "com.mamikaplaan.sana",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "***REMOVED***"
        }
      },
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Rotayı dışarıda takip ederken konumunu haritada göstermek için."
        }
      ],
      "expo-font"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/d657a049-d387-4d43-8d8f-ceace124fdfc"
    },
    "extra": {
      "eas": {
        "projectId": "d657a049-d387-4d43-8d8f-ceace124fdfc"
      }
    },
    "owner": "mamikaplaan"
  }
}
