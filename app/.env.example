# Kopyala: cp .env.example .env  → değerleri doldur. (.env gitignore'ludur.)

# Google Maps Android SDK anahtarı (app.config.js → android.config.googleMaps)
# EAS build için ayrıca: eas secret:create --name GOOGLE_MAPS_API_KEY --value <KEY>
GOOGLE_MAPS_API_KEY=

# Dev otomatik giriş (yalnızca AUTH_ENABLED=false iken kullanılır; opsiyonel)
EXPO_PUBLIC_DEV_EMAIL=
EXPO_PUBLIC_DEV_PASSWORD=

# Servis bot kalkanı (#3a): anonim maliyet uçlarına gönderilen paylaşımlı sır.
# ai-service'teki SANA_APP_SECRET ile AYNI değer olmalı. Boşsa kontrol devre dışı.
EXPO_PUBLIC_APP_KEY=
